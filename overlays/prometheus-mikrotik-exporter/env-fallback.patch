Honor MIKROTIK_USER / MIKROTIK_PASSWORD env vars in config-file mode.

Upstream's loadConfigFromFlags() already falls back to env vars when -user
or -password are missing in single-device CLI mode. The config-file path
silently ignores them. This patch mirrors the same fallback for any device
in the loaded config whose user or password is empty, so credentials can be
provided via a systemd EnvironmentFile (e.g., from agenix) without baking
them into a YAML.

--- a/main.go
+++ b/main.go
@@ -115,7 +115,26 @@ func loadConfigFromFile() (*config.Config, error) {
 		return nil, err
 	}

-	return config.Load(bytes.NewReader(b))
+	cfg, err := config.Load(bytes.NewReader(b))
+	if err != nil {
+		return nil, err
+	}
+
+	// Fall back to MIKROTIK_USER / MIKROTIK_PASSWORD env vars for any device
+	// whose user/password is unset in the config file. Mirrors the env-var
+	// handling already done for single-device CLI mode (loadConfigFromFlags).
+	envUser := os.Getenv("MIKROTIK_USER")
+	envPass := os.Getenv("MIKROTIK_PASSWORD")
+	for i := range cfg.Devices {
+		if cfg.Devices[i].User == "" {
+			cfg.Devices[i].User = envUser
+		}
+		if cfg.Devices[i].Password == "" {
+			cfg.Devices[i].Password = envPass
+		}
+	}
+
+	return cfg, nil
 }

